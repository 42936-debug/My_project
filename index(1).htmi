<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Teachable Machine Image Model</title>
    <style>
        :root {
            --primary: #4f46e5;
            --primary-hover: #4338ca;
            --background: #f8fafc;
            --card: #ffffff;
            --text: #1e293b;
            --text-light: #64748b;
            --success: #10b981;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--background);
            color: var(--text);
            margin: 0;
            padding: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .card {
            background-color: var(--card);
            border-radius: 16px;
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
            padding: 2rem;
            width: 100%;
            max-width: 400px;
            text-align: center;
        }

        h1 {
            font-size: 1.5rem;
            font-weight: 600;
            margin-top: 0;
            margin-bottom: 1.5rem;
            color: #0f172a;
        }

        .btn {
            background-color: var(--primary);
            color: white;
            border: none;
            padding: 0.75rem 2rem;
            font-size: 1rem;
            font-weight: 500;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.2s ease;
            box-shadow: 0 4px 6px -1px rgba(79, 70, 229, 0.4);
            width: 100%;
            box-sizing: border-box;
        }

        .btn:hover {
            background-color: var(--primary-hover);
            transform: translateY(-1px);
        }

        .btn:active {
            transform: translateY(1px);
        }

        #webcam-container {
            margin: 1.5rem auto;
            border-radius: 12px;
            overflow: hidden;
            width: 200px;
            height: 200px;
            background-color: #e2e8f0;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: inset 0 2px 4px 0 rgba(0, 0, 0, 0.06);
            transition: outline 0.15s ease-in-out;
        }

        /* เอฟเฟกต์กะพริบสีเขียวรอบกล้องเพื่อแสดงว่าระบบกำลังบันทึกภาพไปประมวลผล */
        .scanning {
            outline: 4px solid var(--success);
        }

        #webcam-container canvas {
            display: block;
        }

        #label-container {
            margin-top: 1.5rem;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .prediction-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background-color: #f1f5f9;
            padding: 0.75rem 1rem;
            border-radius: 8px;
            font-weight: 500;
            font-size: 0.95rem;
        }

        .percentage {
            color: var(--primary);
            font-weight: 600;
        }
    </style>
</head>
<body>

<div class="card">
    <h1>Teachable Machine Image Model</h1>
    <button type="button" class="btn" id="start-btn" onclick="init()">Start Camera</button>
    
    <div id="webcam-container"></div>
    <div id="label-container"></div>
</div>

<script src="https://cdn.jsdelivr.net/npm/@tensorflow/tfjs@latest/dist/tf.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@teachablemachine/image@latest/dist/teachablemachine-image.min.js"></script>
<script type="text/javascript">
    // อัปเดตลิงก์โมเดลให้ตรงกับไฟล์ปัจจุบันของคุณแล้ว
    const URL = "https://teachablemachine.withgoogle.com/models/j05lmzuHi/";

    let model, webcam, labelContainer, maxPredictions;
    let predictInterval;

    async function init() {
        // ซ่อนปุ่ม Start หลังจากกดเพื่อไม่ให้ผู้ใช้กดซ้ำ
        document.getElementById("start-btn").style.display = "none";

        const modelURL = URL + "model.json";
        const metadataURL = URL + "metadata.json";

        // โหลดโมเดลและเมทาดาตา
        model = await tmImage.load(modelURL, metadataURL);
        maxPredictions = model.getTotalClasses();

        // ตั้งค่ากล้องเว็บแคม
        const flip = true; 
        webcam = new tmImage.Webcam(200, 200, flip); 
        await webcam.setup(); 
        await webcam.play();
        
        // วนลูปเพื่อให้อัปเดตภาพเคลื่อนไหวบนหน้าจอได้ลื่นไหล
        window.requestAnimationFrame(loop);

        // นำ Element กล้องไปแสดงบนเว็บ
        const webcamContainer = document.getElementById("webcam-container");
        webcamContainer.appendChild(webcam.canvas);
        
        // เตรียมโครงสร้างแสดงผลข้อความทำนายผล
        labelContainer = document.getElementById("label-container");
        for (let i = 0; i < maxPredictions; i++) {
            const item = document.createElement("div");
            item.className = "prediction-item";
            labelContainer.appendChild(item);
        }

        // 🎯 สั่งให้เรียกใช้ฟังก์ชันทำนายผล (predict) ทุก ๆ 3 วินาที (3000 มิลลิวินาที)
        predictInterval = setInterval(async () => {
            // เพิ่มเอฟเฟกต์กระพริบกรอบสีเขียวขณะตรวจจับภาพ
            webcamContainer.classList.add("scanning");
            await predict();
            setTimeout(() => {
                webcamContainer.classList.remove("scanning");
            }, 250);
        }, 3000);
    }

    async function loop() {
        webcam.update(); // อัปเดตภาพจากเฟรมกล้องเพื่อให้ภาพบนหน้าจอเคลื่อนไหวต่อเนื่อง
        window.requestAnimationFrame(loop);
    }

    async function predict() {
        const prediction = await model.predict(webcam.canvas);
        for (let i = 0; i < maxPredictions; i++) {
            const className = prediction[i].className;
            // แปลงค่าทศนิยมของโอกาสความน่าจะเป็นให้กลายเป็นเปอร์เซ็นต์เพื่อให้ผู้ใช้อ่านง่ายขึ้น
            const percent = (prediction[i].probability * 100).toFixed(0);
            
            labelContainer.childNodes[i].innerHTML = `
                <span>${className}</span>
                <span class="percentage">${percent}%</span>
            `;
        }
    }
</script>

</body>
</html>
